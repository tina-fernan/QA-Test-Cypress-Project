{
  "name": "qa-cypress-ecommerce",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "report:merge": "mochawesome-merge cypress/reports/*.json -o cypress/reports/report.json",
    "report:generate": "marge cypress/reports/report.json -f report -o cypress/reports",
    "test:report": "npm run test && npm run report:merge && npm run report:generate",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:allure": "npm run test && npm run allure:generate && npm run allure:open"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@shelex/cypress-allure-plugin": "^2.41.2",
    "allure-commandline": "^2.38.1",
    "cypress": "^15.13.1",
    "cypress-dotenv": "^3.0.1",
    "dotenv": "^17.4.1",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.1",
    "mochawesome-report-generator": "^6.3.2"
  }
}
